{
    "name": "swarmui-base2edit-extension",
    "version": "1.0.0",
    "description": "Base2Edit extension for SwarmUI - multi-stage edit workflows",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "npm run lint && npm run check && node ./scripts/build.mjs",
        "check": "npm run format:check && npm run lint && npm run typecheck",
        "clean": "rm -f Assets/base2edit.js Assets/base2edit.js.map",
        "coverage:functions": "npm run test:coverage && node ./scripts/report-uncovered-functions.mjs",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "lint": "biome check --write .",
        "test": "jest --config ./jest.config.cjs --passWithNoTests",
        "test:coverage": "jest --config ./jest.config.cjs --coverage --passWithNoTests",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.11",
        "@jest/globals": "^30.3.0",
        "esbuild": "^0.28.0",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "ts-jest": "^29.4.9",
        "typescript": "^6.0.2"
    }
}
